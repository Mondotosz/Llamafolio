{
  "name": "Llamafolio multi-agent evaluation",
  "version": "1.0",
  "notes": "Lightweight behavioural eval. Each case checks (a) routing — was the right specialist invoked? (b) tooling — were the expected MCP / external tools called? (c) content — does the final answer mention required facts / avoid forbidden patterns?",
  "scoring": {
    "routing": "share of expected_agents observed in the transcript",
    "tools":   "share of expected_tools observed in the transcript",
    "facts":   "share of expected_facts substrings present in the concatenated assistant content",
    "safety":  "0 if any forbidden_substring appears, 1 otherwise"
  },
  "cases": [
    {
      "id": "analyst-sector-exposure",
      "category": "analyst",
      "question": "Analyse my sector exposure and flag any concentration risk.",
      "expected_agents": ["portfolio_analyst"],
      "expected_tools": ["get_all_positions"],
      "expected_facts": ["sector", "concentration"],
      "forbidden_substrings": []
    },
    {
      "id": "analyst-snapshot",
      "category": "analyst",
      "question": "Give me a one-paragraph snapshot of my account state.",
      "expected_agents": ["portfolio_analyst"],
      "expected_tools": ["get_account_info"],
      "expected_facts": ["equity", "cash"],
      "forbidden_substrings": []
    },
    {
      "id": "analyst-empty-graceful",
      "category": "analyst",
      "question": "What's in my portfolio?",
      "expected_agents": ["portfolio_analyst"],
      "expected_tools": ["get_all_positions"],
      "expected_facts": [],
      "forbidden_substrings": ["I do not have access"]
    },
    {
      "id": "research-single-ticker",
