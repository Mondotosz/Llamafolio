# Copy this file to .env and fill in your keys.
# Never commit .env.

# --- Alpaca (paper trading) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- LLM provider selection ---
# Choose which provider drives the agents: "gemini" | "groq" | "ollama".
LLM_PROVIDER=gemini

# --- Groq (used when LLM_PROVIDER=groq) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# --- Gemini (used when LLM_PROVIDER=gemini) ---
# Get a free key at https://aistudio.google.com/apikey
#
# Use a non-thinking model. Gemini 2.5 "thinking" models (e.g.
# `gemini-flash-latest` which aliases to gemini-2.5-flash) enforce a
# `thought_signature` contract on every prior functionCall in the history,
# but langgraph-supervisor synthesises handoff tool calls without one,
# which makes the second LLM round-trip fail with 400 INVALID_ARGUMENT.
# `gemini-2.5-flash-lite` is non-thinking and works with our supervisor.
#
# Also avoid `gemini-2.0-flash` — it's being deprecated in the free tier
# and returns 'limit: 0' RESOURCE_EXHAUSTED errors.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Ollama (used when LLM_PROVIDER=ollama, no API key needed) ---
# Recommended models (tool-calling compatible, thinking mode disabled automatically):
#   8 GB VRAM  (e.g. RTX 3070 Mobile) → qwen3.5:4b   (3.4 GB, 6.2GB VRAM)
#   16 GB VRAM (e.g. RTX 5080)        → qwen3.5:9b   (6.6 GB, 8.9GB VRAM)
# Pull with: ollama pull qwen3.5:9b
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_BASE_URL=http://localhost:11434

# --- Tavily (web search) ---
TAVILY_API_KEY=

# --- LangSmith (tracing, optional) ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=llamafolio
# Use https://eu.api.smith.langchain.com if your account is in the EU region
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
