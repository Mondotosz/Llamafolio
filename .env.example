# Copy this file to .env and fill in your keys.
# Never commit .env.

# --- Alpaca (paper trading) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- LLM provider selection ---
# Choose which provider drives the agents: "groq" or "gemini".
LLM_PROVIDER=gemini

# --- Groq (used when LLM_PROVIDER=groq) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# --- Gemini (used when LLM_PROVIDER=gemini) ---
# Get a free key at https://aistudio.google.com/apikey
# Use `gemini-flash-latest` — `gemini-2.0-flash` is being deprecated in the
# free tier and returns 'limit: 0' RESOURCE_EXHAUSTED errors.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- Tavily (web search) ---
TAVILY_API_KEY=

# --- LangSmith (tracing, optional) ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=llamafolio
# Use https://eu.api.smith.langchain.com if your account is in the EU region
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
